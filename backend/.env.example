# ================================
# NETRIOS NEWS - ENVIRONMENT VARIABLES
# ================================
# Copie este arquivo para .env e preencha com suas credenciais
# NUNCA commit o arquivo .env!

# --------------------------------
# Server Configuration
# --------------------------------
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# --------------------------------
# Database (Supabase Postgres)
# --------------------------------
DATABASE_URL=postgresql://user:password@host:port/database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# --------------------------------
# Redis (Upstash - BullMQ Queue)
# --------------------------------
REDIS_URL=rediss://default:password@host:port

# --------------------------------
# Search Provider
# --------------------------------
SEARCH_BACKEND=google
# Google Custom Search API
GOOGLE_SEARCH_API_KEY=AIzaSyDRdRSDRSk84syc7a3I_fOgZYmpTkHtSHA
GOOGLE_SEARCH_ENGINE_ID=your-search-engine-id
# Alternativa: SerpAPI (se migrar no futuro)
# SERPAPI_KEY=your-serpapi-key

# --------------------------------
# Content Fetcher
# --------------------------------
CONTENT_BACKEND=jina
# Jina AI Reader API
JINA_API_KEY=your-jina-api-key
# Alternativa: Firecrawl (se migrar no futuro)
# FIRECRAWL_API_KEY=your-firecrawl-key

# --------------------------------
# LLM Provider (OpenAI)
# --------------------------------
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --------------------------------
# Push Notifications (Firebase)
# --------------------------------
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
# Ou use caminho para arquivo JSON:
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# --------------------------------
# Rate Limiting & Budget
# --------------------------------
# Limites padrão (serão sobrescritos pelo DB)
DEFAULT_GOOGLE_MAX_CONCURRENT=5
DEFAULT_GOOGLE_MIN_TIME_MS=100
DEFAULT_JINA_MAX_CONCURRENT=10
DEFAULT_JINA_MIN_TIME_MS=100
DEFAULT_OPENAI_MAX_CONCURRENT=5
DEFAULT_OPENAI_MIN_TIME_MS=200

# Budget alertas
MONTHLY_BUDGET_USD=100
BUDGET_WARNING_THRESHOLD=0.9

# --------------------------------
# Caching (Redis TTL)
# --------------------------------
CACHE_JINA_CONTENT_TTL=86400
CACHE_EMBEDDING_TTL=2592000

# --------------------------------
# CRON Schedule
# --------------------------------
SCAN_CRON_SCHEDULE=0 * * * *

# --------------------------------
# Logging
# --------------------------------
LOG_LEVEL=info
LOG_FILE=logs/app.log

# --------------------------------
# Security
# --------------------------------
CORS_ORIGIN=http://localhost:3001,https://admin.netriosnews.com
JWT_SECRET=your-jwt-secret-change-in-production

# --------------------------------
# Admin Panel URL (para CORS)
# --------------------------------
ADMIN_PANEL_URL=http://localhost:3001

# --------------------------------
# Mobile App (para testes)
# --------------------------------
MOBILE_APP_PACKAGE_NAME=com.netriosnews.app
